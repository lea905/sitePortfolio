{% extends 'base.html.twig' %}

{% block body %}
    <!-- HERO SECTION -->
    <section id="hero-section" class="d-flex align-items-center justify-content-center text-center py-5" style="min-height: 80vh; padding-top: 80px;">
        <div class="container">
            <div class="hero-content">
                <p class="hero-subtitle lead text-muted mx-auto mb-4" style="max-width: 600px;">Bonjour, je suis Léa Barnezet</p>
                <h1 class="display-3 fw-bold mb-3">Développeuse <span style="color: var(--accent);">Full Stack</span></h1>
                <p class="hero-description text-muted mx-auto mb-5" style="max-width: 600px; font-size: 1.1rem;">
                    Je conçois des applications web robustes et modernes. Actuellement à la recherche d’une nouvelle opportunité en CDI ou CDD à Bourg-en-Bresse, Lyon ou dans ses alentours.
                </p>
                <div class="hero-actions d-flex justify-content-center gap-3 flex-wrap">
                    <a href="#projets" class="btn btn-primary px-4 py-2">Voir mes projets</a>
                    <a href="{{ asset('cv_FR.pdf') }}" target="_blank" class="btn btn-outline px-4 py-2">Télécharger mon CV</a>
                </div>
            </div>
        </div>
    </section>

    <!-- SKILLS SECTION -->
    <section id="competences" class="py-5">
        <div class="container">
            <h2 class="section-title text-center mb-5">Mes Compétences</h2>

            <div class="skills-category text-center mb-5">
                <h3 class="mb-4 text-muted fs-4">Languages Informatiques</h3>
                <div class="row justify-content-center g-4">
                    <div class="col-auto">
                        <div class="skill-card" style="--skill-color: #e34c26;">
                            <span class="skill-name">HTML</span>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="skill-card" style="--skill-color: #264de4;">
                            <span class="skill-name">CSS</span>
                        </div>
                    </div>
                    <div class="col-auto">
                         <div class="skill-card" style="--skill-color: #f0db4f;">
                            <span class="skill-name">JS</span>
                        </div>
                    </div>
                    <div class="col-auto">
                         <div class="skill-card" style="--skill-color: #777bb4;">
                            <span class="skill-name">PHP</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="skills-category text-center mb-5">
                <h3 class="mb-4 text-muted fs-4">Frameworks</h3>
                <div class="row justify-content-center g-4">
                    <div class="col-auto">
                         <div class="skill-card" style="--skill-color: #000000">
                            <span class="skill-name">Symfony</span>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="skill-card" style="--skill-color: #6cc24a;">
                            <span class="skill-name">Node.js</span>
                        </div>
                    </div>
                    <div class="col-auto">
                         <div class="skill-card" style="--skill-color: #02569b;">
                            <span class="skill-name">Flutter</span>
                        </div>
                    </div>
                </div>
            </div>

             <div class="skills-category text-center mb-5">
                <h3 class="mb-4 text-muted fs-4">Outils & Système</h3>
                <div class="row justify-content-center g-4">
                    <div class="col-auto">
                         <div class="skill-card" style="--skill-color: #fcc624;">
                            <span class="skill-name">Linux</span>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="skill-card" style="--skill-color: #003b57;">
                            <span class="skill-name">SQL</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a href="{{ path('app_competences') }}" class="btn btn-outline">Voir toutes mes compétences &rarr;</a>
            </div>

        </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section id="projets" class="py-5" style="background-color: var(--bg-alt);">
        <div class="container">
            <h2 class="section-title text-center mb-5">Projets Récents</h2>

            <div class="row g-4">
                {% for project in projects %}
                    <div class="col-12 col-md-6 col-lg-4">
                        <article class="project-card d-flex flex-column h-100" style="background: var(--bg-body); border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color); transition: transform 0.3s ease;">
                            <div class="project-image position-relative" style="height: 200px; background-color: #2d2d2d; overflow: hidden;">
                                {% if project.image %}
                                    {% set main_img = project.image %}
                                    {% if project.image and not project.image starts with 'http' and not project.image starts with '/' and not ('/' in project.image) %}
                                        {% set main_img = 'img/projects/' ~ project.image %}
                                    {% endif %}
                                    <img src="{{ asset(main_img) }}" alt="{{ project.title }}" class="w-100 h-100 object-fit-cover">
                                {% else %}
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <span class="text-muted">{{ project.title }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="project-content p-4 d-flex flex-column flex-grow-1">
                                 <div class="project-tags d-flex flex-wrap gap-2 mb-3">
                                    {% if project.technologies %}
                                        {% for tech in project.technologies|split(',') %}
                                            <span class="badge" style="background: rgba(168, 85, 247, 0.1); color: var(--accent); font-weight: 500;">{{ tech|trim }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                                <h3 class="mb-2 fs-4">{{ project.title }}</h3>
                                <p class="text-muted small mb-4 flex-grow-1">
                                    {{ project.description|striptags|slice(0, 100) ~ (project.description|length > 100 ? '...' : '') }}
                                </p>

                                <div class="mt-auto d-flex align-items-center flex-wrap gap-3">
                                    <a href="{{ path('app_project_show', {'id': project.id}) }}" class="text-decoration-none text-light d-inline-flex align-items-center gap-2 border rounded px-3 py-1 fw-medium" style="border-color: var(--border-color) !important; font-size: 0.85rem;">
                                        Détails &rarr;
                                    </a>
                                    {% if project.link %}
                                        <a href="{{ project.link }}" target="_blank" class="text-decoration-none d-inline-flex align-items-center gap-2 fw-medium" style="color: var(--accent); font-size: 0.85rem;">
                                            Lien final &rarr;
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </article>
                    </div>
                {% else %}
                     <div class="col-12">
                         <p class="text-muted text-center">Aucun projet récent trouvé.</p>
                     </div>
                {% endfor %}
            </div>

            <div class="text-center mt-5">
                <a href="{{ path('app_project') }}" class="btn btn-outline">Voir tous les projets &rarr;</a>
            </div>
        </div>
    </section>

    <!-- CONTACT / FOOTER CALLOUT -->
    <section id="contact" class="py-5 text-center">
        <div class="container">
            <h2 class="mb-3">Prêt à collaborer ?</h2>
            <p class="text-muted mb-4 pb-2">Je suis disponible pour discuter de vos projets ou d'opportunités de carrière.</p>
            <a href="mailto:Barnezet905@gmail.com" class="btn btn-primary px-4 py-2">Me Contacter</a>
        </div>
    </section>
{% endblock %}
