{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} | Léa Barnezet{% endblock %}

{% block body %}
    <section class="py-5" style="background-color: #080c1f; min-height: 100vh;">
        <div class="container pt-5">
            <a href="{{ path('app_project') }}" class="text-decoration-none d-inline-block mb-4" style="color: var(--accent);">&larr; Retour aux projets</a>

            <h1 class="section-title mb-5 display-5 fw-bold text-light">{{ project.title }}</h1>

            <div class="row gy-5 mb-5">
                <div class="col-12">
                     <div class="card bg-transparent border-0 overflow-hidden" style="background: var(--bg-card) !important; border-radius: 12px; border: 1px solid var(--border-color) !important;">
                        {% if project.image %}
                            <img src="{{ asset(project.image) }}" alt="{{ project.title }}" class="card-img-top w-100 object-fit-cover" style="max-height: 600px;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center" style="height: 400px; background-color: #1a1f35;">
                                <span class="text-muted">Image non disponible</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="col-12">
                    <div class="card bg-transparent border-0 p-4 p-md-5" style="background: var(--bg-card) !important; border-radius: 12px; border: 1px solid var(--border-color) !important;">
                        <div class="project-tags d-flex flex-wrap gap-2 mb-4">
                            {% if project.technologies %}
                                {% for tech in project.technologies|split(',') %}
                                    <span class="badge py-2 px-3 fw-medium" style="background: rgba(168, 85, 247, 0.1); color: var(--accent); font-size: 0.95rem;">{{ tech|trim }}</span>
                                {% endfor %}
                            {% endif %}
                        </div>

                        {% if project.duration %}
                            <div class="mb-4">
                                <span class="badge d-inline-flex align-items-center py-2 px-3 fw-normal" style="background: rgba(255, 255, 255, 0.05); color: var(--text-main); font-size: 0.95rem;">
                                    {{ project.duration }}
                                </span>
                            </div>
                        {% endif %}

                        {% if project.contexte %}
                            <h3 class="text-light mb-4 fs-3 fw-bold">Contexte</h3>
                            <div class="text-muted fs-5 lh-lg mb-5" style="white-space: pre-wrap;">{{ project.contexte }}</div>
                        {% endif %}

                        <h3 class="text-light mb-4 fs-3 fw-bold">Description</h3>
                        <div class="text-muted fs-5 lh-lg mb-5" style="white-space: pre-wrap;">{{ project.description }}</div>

                        {% if project.images is defined and project.images|length > 0 %}
                            <h3 class="text-light mb-4 fs-3 fw-bold">Galerie</h3>
                            <div class="row g-4 mb-5">
                                {% for image in project.images %}
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="gallery-item glass-card overflow-hidden" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#imageModal{{ loop.index }}">
                                            <img src="{{ asset(image.imageName) }}" alt="Image {{ loop.index }} pour {{ project.title }}" class="img-fluid w-100 object-fit-cover" style="height: 250px; transition: transform 0.3s ease;">
                                        </div>
                                    </div>

                                    <!-- Modal for each image -->
                                    <div class="modal fade" id="imageModal{{ loop.index }}" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-xl modal-dialog-centered">
                                            <div class="modal-content bg-dark border-0">
                                                <div class="modal-header border-0">
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-0 text-center">
                                                    <img src="{{ asset(image.imageName) }}" alt="Image {{ loop.index }}" class="img-fluid">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if project.link %}
                            <div class="mt-4">
                                <a href="{{ project.link }}" target="_blank" class="btn btn-primary btn-lg d-inline-flex align-items-center gap-2 px-4 py-3">
                                    Git &rarr;
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
