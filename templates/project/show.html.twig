{% extends 'base.html.twig' %}

{% block title %}{{ project.title }} | Léa Barnezet{% endblock %}

{% block body %}
    <section class="py-5" style="background-color: #080c1f; min-height: 100vh;">
        <div class="container pt-5">
            <a href="{{ path('app_project') }}" class="text-decoration-none d-inline-block mb-4" style="color: var(--accent);">&larr; Retour aux projets</a>

            <h1 class="section-title mb-5 display-5 fw-bold text-light">{{ project.title }}</h1>

            <div class="row gy-5 mb-5">
                <div class="col-12">
                     <div class="card bg-transparent border-0 overflow-hidden" style="background: var(--bg-card) !important; border-radius: 12px; border: 1px solid var(--border-color) !important;">
                        {% if project.image %}
                            {% set main_img = project.image %}
                            {% if project.image and not project.image starts with 'http' and not project.image starts with '/' and not ('/' in project.image) %}
                                {% set main_img = 'img/projects/' ~ project.image %}
                            {% endif %}
                            <img src="{{ asset(main_img) }}" alt="{{ project.title }}" class="card-img-top w-100 object-fit-cover" style="max-height: 600px;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center" style="height: 400px; background-color: #1a1f35;">
                                <span class="text-muted">Image non disponible</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="col-12">
                    <div class="card bg-transparent border-0 p-4 p-md-5" style="background: var(--bg-card) !important; border-radius: 12px; border: 1px solid var(--border-color) !important;">
                        <div class="project-tags d-flex flex-wrap gap-2 mb-4">
                            {% if project.technologies %}
                                {% for tech in project.technologies|split(',') %}
                                    <span class="badge py-2 px-3 fw-medium" style="background: rgba(168, 85, 247, 0.1); color: var(--accent); font-size: 0.95rem;">{{ tech|trim }}</span>
                                {% endfor %}
                            {% endif %}
                        </div>

                        {% if project.duration %}
                            <div class="mb-4">
                                <span class="badge d-inline-flex align-items-center py-2 px-3 fw-normal" style="background: rgba(255, 255, 255, 0.05); color: var(--text-main); font-size: 0.95rem;">
                                    {{ project.duration }}
                                </span>
                            </div>
                        {% endif %}

                        {% if project.contexte %}
                            <h3 class="text-light mb-4 fs-3 fw-bold">Contexte</h3>
                            <div class="text-muted fs-5 lh-lg mb-5" style="white-space: pre-wrap;">{{ project.contexte }}</div>
                        {% endif %}

                        <h3 class="text-light mb-4 fs-3 fw-bold">Description</h3>
                        <div class="text-muted fs-5 lh-lg mb-5" style="white-space: pre-wrap;">{{ project.description }}</div>

                        {% if project.images is defined and project.images|length > 0 %}
                            <h3 class="text-light mb-4 fs-3 fw-bold">Galerie</h3>
                            <div class="row g-4 mb-5">
                                {% for image in project.images %}
                                    {% set img_path = image.imageName %}
                                    {% if img_path and not img_path starts with 'http' and not img_path starts with '/' and not ('/' in img_path) %}
                                        {% set img_path = 'img/projects/' ~ img_path %}
                                    {% endif %}
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="gallery-item glass-card position-relative overflow-hidden" style="cursor: pointer; border-radius: 16px; aspect-ratio: 4/3;" data-bs-toggle="modal" data-bs-target="#imageModal{{ loop.index }}">
                                            <img src="{{ asset(img_path) }}" alt="Image {{ loop.index }} pour {{ project.title }}" class="img-fluid w-100 h-100 object-fit-cover shadow-sm" style="transition: transform 0.5s ease;">
                                            <div class="gallery-overlay position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="background: rgba(168, 85, 247, 0.15); opacity: 0; transition: opacity 0.4s ease; backdrop-filter: blur(3px);">
                                                <i class="fas fa-expand text-white border border-white rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; font-size: 1.2rem; background: rgba(0,0,0,0.3); transform: translateY(20px); transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Modal for each image -->
                                    <div class="modal fade" id="imageModal{{ loop.index }}" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
                                        <div class="modal-dialog modal-xl modal-dialog-centered">
                                            <div class="modal-content bg-transparent border-0 shadow-none">
                                                <div class="modal-header border-0 position-absolute top-0 end-0 z-3" style="padding: 1rem;">
                                                    <button type="button" class="btn-close custom-modal-close shadow-lg" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-0 text-center">
                                                    <img src="{{ asset(img_path) }}" alt="Image {{ loop.index }}" class="img-fluid rounded-4 shadow-lg" style="max-height: 90vh; object-fit: contain;">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if project.link %}
                            <div class="mt-4">
                                <a href="{{ project.link }}" target="_blank" class="btn btn-primary btn-lg d-inline-flex align-items-center gap-2 px-4 py-3">
                                    Git &rarr;
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
