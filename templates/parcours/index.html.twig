{% extends 'base.html.twig' %}

{% block title %}Mon Parcours | Léa Barnezet{% endblock %}

{% block body %}
    <section class="py-5" style="min-height: 100vh;">
        <div class="container pt-5">
            <h1 class="section-title text-center mb-5 display-5 fw-bold mt-4">Mon Parcours</h1>

            <div class="row g-5">
                
                <div class="col-12 col-lg-6">
                    <h2 class="mb-4 text-center fs-3 fw-bold text-light">Expériences Professionnelles</h2>
                    <div class="timeline">
                        {% for exp in experiences %}
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-date">{{ exp.date }}</div>
                                <div class="timeline-content glass-card p-4">
                                    <h3 class="fs-5 fw-bold text-light mb-2">{{ exp.title }}</h3>
                                    <h4 class="fs-6 mb-3" style="color: var(--accent);">{{ exp.company }}, {{ exp.type }}</h4>
                                    <p class="text-muted small mb-0">{{ exp.description }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <h2 class="mb-4 text-center fs-3 fw-bold text-light">Formations</h2>
                    <div class="timeline">
                        {% for form in formations %}
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-date">{{ form.date }}</div>
                                <div class="timeline-content glass-card p-4">
                                    <h3 class="fs-5 fw-bold text-light mb-2">{{ form.title }}</h3>
                                    <h4 class="fs-6 mb-3" style="color: var(--accent);">{{ form.school }}, {{ form.type }}</h4>
                                    <p class="text-muted small mb-0">{{ form.description }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

            </div>
        </div>
    </section>
{% endblock %}
